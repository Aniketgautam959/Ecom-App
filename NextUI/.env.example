# ============================================================
# NextJS / NextUI Frontend Environment Variables
# Copy this file to .env.local and fill the required values.
# ============================================================

# --- REQUIRED: Public App Branding ---
NEXT_PUBLIC_APP_NAME=My App

# --- REQUIRED: Public Site URL (used for SEO, sitemap, links) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- REQUIRED: Public API URL ---
# In the browser this is used as the fetch base path. It can be:
#   /api          -> Next.js rewrites to the backend
#   http://...    -> Direct backend URL
NEXT_PUBLIC_API_URL=/api

# --- REQUIRED: Server-side Laravel Backend URL ---
# Used by Next.js server components and rewrites to reach the Laravel API.
LARAVEL_INTERNAL_URL=http://127.0.0.1:8000

# --- OPTIONAL: Laravel backend origin for public storage URLs ---
# If NEXT_PUBLIC_API_URL is a relative path, set this to the backend
# origin so uploaded images/banners can be served to the browser.
# If not set, LARAVEL_INTERNAL_URL is used as a fallback.
NEXT_PUBLIC_LARAVEL_ORIGIN=http://127.0.0.1:8000

# --- OPTIONAL: Razorpay public key (only needed if you use Razorpay) ---
# This is the Razorpay key ID. It is safe to expose to the browser.
# The backend secret is in LaraBackend/.env
NEXT_PUBLIC_RAZORPAY_KEY=your_razorpay_key_id
